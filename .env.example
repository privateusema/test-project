# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # Claude API key (~/keys/claude-api-key-1.key)

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=           # AWS credentials (S3 backup, fallback services)
AWS_SECRET_ACCESS_KEY=       # AWS secret key
AWS_DEFAULT_REGION=us-east-2 # AWS region (matches mono-repo S3 bucket)

# ── MCP Servers ───────────────────────────────────────────────────────────────
DIGITALOCEAN_API_TOKEN=      # DigitalOcean MCP (~/keys/do-mcp-api-key-1.key)
CLOUDFLARE_API_TOKEN=        # Cloudflare MCP (~/keys/cf-mcp-api-key-1.key)
CLOUDFLARE_ACCOUNT_ID=       # Cloudflare account (~/keys/cloudflare-account-id.txt)
GITHUB_PERSONAL_ACCESS_TOKEN= # GitHub MCP (~/keys/github-pat-1.key)
SUPABASE_ACCESS_TOKEN=       # Supabase MCP personal access token (~/keys/supabase-mcp-key-1)

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=                # Supabase project URL (https://<ref>.supabase.co)
SUPABASE_ANON_KEY=           # Supabase publishable key — safe for client-side (~/keys/supabase-publishable-key.key)
SUPABASE_SERVICE_ROLE_KEY=   # Supabase secret key — server-side only (~/keys/supabase-secret-key.key)

# ── Cache (L5) ───────────────────────────────────────────────────────────────
# VALKEY_URL=                # Managed Valkey connection string (rediss://...:25061)
                             # Discover via MCP: db-cluster-get or db-cluster-list
                             # Use private URI when running on DOKS (same VPC)

# ── Observability (L6) ───────────────────────────────────────────────────────
LANGCHAIN_API_KEY=           # LangSmith API key (~/keys/langsmith-api-key-1.key)
LANGCHAIN_TRACING_V2=true    # Enable LangSmith tracing
LANGCHAIN_PROJECT=test-project
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # LangSmith endpoint (default)
